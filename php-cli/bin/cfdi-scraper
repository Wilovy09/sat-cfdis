#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

use GuzzleHttp\Client as GuzzleClient;
use GuzzleHttp\Cookie\CookieJar;
use PhpCfdi\CfdiSatScraper\Filters\DownloadType;
use PhpCfdi\CfdiSatScraper\Filters\Options\StatesVoucherOption;
use PhpCfdi\CfdiSatScraper\QueryByFilters;
use PhpCfdi\CfdiSatScraper\ResourceType;
use PhpCfdi\CfdiSatScraper\SatHttpGateway;
use PhpCfdi\CfdiSatScraper\SatScraper;
use PhpCfdi\CfdiSatScraper\Sessions\Ciec\CiecSessionManager;
use PhpCfdi\CfdiSatScraper\Sessions\Fiel\FielSessionManager;
use PhpCfdi\Credentials\Credential;
use PhpCfdi\ImageCaptchaResolver\CaptchaAnswer;
use PhpCfdi\ImageCaptchaResolver\CaptchaAnswerInterface;
use PhpCfdi\ImageCaptchaResolver\CaptchaImageInterface;
use PhpCfdi\ImageCaptchaResolver\CaptchaResolverInterface;
use PhpCfdi\SatWsDescargaMasiva\PackageReader\CfdiPackageReader;
use PhpCfdi\SatWsDescargaMasiva\RequestBuilder\FielRequestBuilder\Fiel;
use PhpCfdi\SatWsDescargaMasiva\RequestBuilder\FielRequestBuilder\FielRequestBuilder;
use PhpCfdi\SatWsDescargaMasiva\Service;
use PhpCfdi\SatWsDescargaMasiva\Services\Query\QueryParameters;
use PhpCfdi\SatWsDescargaMasiva\Shared\DateTimePeriod;
use PhpCfdi\SatWsDescargaMasiva\Shared\DownloadType as WsDownloadType;
use PhpCfdi\SatWsDescargaMasiva\Shared\RequestType;
use PhpCfdi\SatWsDescargaMasiva\Shared\StatusRequest;
use PhpCfdi\SatWsDescargaMasiva\WebClient\GuzzleWebClient;

/**
 * Captcha resolver that asks the user via browser.
 *
 * Writes a JSON event to stdout so Rust forwards it to the browser as SSE.
 * Then reads the user's answer from stdin (written by Rust after the browser POSTs it).
 */
final class UserCaptchaResolver implements CaptchaResolverInterface
{
    public function resolve(CaptchaImageInterface $image): CaptchaAnswerInterface
    {
        // Emit captcha event — Rust picks this up and sends it as SSE to the browser.
        echo json_encode([
            '__captcha__'  => true,
            'image_base64' => $image->asBase64(),
            'mime'         => $image->getMimeType(),
        ], JSON_UNESCAPED_UNICODE) . "\n";
        flush();

        // Block until Rust writes the user's answer to our stdin.
        $answer = trim((string) fgets(STDIN));

        if ($answer === '') {
            throw new \PhpCfdi\ImageCaptchaResolver\UnableToResolveCaptchaException($this, $image);
        }

        return new CaptchaAnswer($answer);
    }
}

/**
 * Selects the best available captcha resolver.
 *
 * Priority:
 *  1. BOXFACTURA_CONFIG_PATH is set and points to a valid YAML config
 *     → uses BoxFactura AI (local ONNX model, fully automatic, no user interaction)
 *  2. Fallback → UserCaptchaResolver (shows image in the browser, user types the answer)
 */
function createCaptchaResolver(): CaptchaResolverInterface
{
    $configPath = getenv('BOXFACTURA_CONFIG_PATH');

    if (
        $configPath
        && file_exists($configPath)
        && class_exists(\PhpCfdi\ImageCaptchaResolver\BoxFacturaAI\BoxFacturaAIResolver::class)
    ) {
        return \PhpCfdi\ImageCaptchaResolver\BoxFacturaAI\BoxFacturaAIResolver::createFromConfigs($configPath);
    }

    return new UserCaptchaResolver();
}

/**
 * Builds the SSL verify value for Guzzle.
 *
 * Priority:
 *  1. VERIFY_SSL=false  → disables certificate verification (dev only)
 *  2. CURL_CA_BUNDLE    → explicit path to a PEM bundle
 *  3. openssl.cafile    → PHP ini (set by Homebrew/system)
 *  4. /etc/ssl/cert.pem → macOS system bundle
 *  5. true              → let cURL decide (works on most Linux EC2s)
 */
function resolveGuzzleVerify(): string|bool
{
    if (strtolower((string) getenv('VERIFY_SSL')) === 'false') {
        return false;
    }
    if ($bundle = getenv('CURL_CA_BUNDLE')) {
        return $bundle;
    }
    if ($bundle = ini_get('curl.cainfo') ?: ini_get('openssl.cafile')) {
        return $bundle;
    }
    foreach (['/etc/ssl/cert.pem', '/etc/ssl/certs/ca-certificates.crt'] as $path) {
        if (file_exists($path)) {
            return $path;
        }
    }
    return true;
}

/**
 * Creates a SatScraper with a Guzzle client configured for the SAT portal.
 *
 * The SAT uses a 1024-bit Diffie-Hellman key which OpenSSL 3.x rejects by
 * default (SECLEVEL=2 requires >=2048-bit DH).  We lower to SECLEVEL=1 via
 * the cipher list so cURL will complete the TLS handshake.
 * This is safe: we are connecting to a known government endpoint and the
 * weakness is on the SAT's server, not in our code.
 */
function makeScraper(
    \PhpCfdi\CfdiSatScraper\Sessions\SessionManager $sessionManager,
): SatScraper {
    $cookieJar = new CookieJar();
    $guzzle = new GuzzleClient([
        'verify' => resolveGuzzleVerify(),
        'curl'   => [
            // Accept the SAT's legacy 1024-bit DH key (OpenSSL 3.x SECLEVEL=1).
            CURLOPT_SSL_CIPHER_LIST => 'DEFAULT@SECLEVEL=1',
        ],
    ]);
    $gateway = new SatHttpGateway($guzzle, $cookieJar);
    return new SatScraper($sessionManager, $gateway);
}

/**
 * Writes a JSON error to stderr and exits with a non-zero code.
 */
function outputError(string $message, int $code = 1): never
{
    fwrite(STDERR, json_encode(['error' => $message], JSON_UNESCAPED_UNICODE) . PHP_EOL);
    exit($code);
}

/**
 * Writes a JSON result to stdout and exits cleanly.
 */
function outputJson(mixed $data): never
{
    echo json_encode($data, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT);
    exit(0);
}

// --------------------------------------------------------------------------
// Disable output buffering globally so captcha events (and SSE lines) are
// flushed to Rust immediately, regardless of which command is running.
while (ob_get_level()) { ob_end_clean(); }
ini_set('output_buffering', 'Off');
ini_set('implicit_flush', '1');

// --------------------------------------------------------------------------
// Read JSON input from stdin (one line — stdin stays open for captcha answers)
// --------------------------------------------------------------------------
$rawInput = fgets(STDIN);
if ($rawInput === false || trim($rawInput) === '') {
    outputError('No input received on stdin');
}

$input = json_decode($rawInput, true);
if (!is_array($input)) {
    outputError('Invalid JSON input: ' . json_last_error_msg());
}

$command = $input['command'] ?? null;
$auth    = $input['auth'] ?? null;
$params  = $input['params'] ?? [];

if (!$command) {
    outputError('Missing required field: command');
}
if (!$auth) {
    outputError('Missing required field: auth');
}

// --------------------------------------------------------------------------
// Build session manager
// --------------------------------------------------------------------------
$authType    = $auth['type'] ?? '';

$scraper = match($authType) {
    'fiel' => (static function () use ($auth): SatScraper {
        foreach (['cert_pem_path', 'key_pem_path'] as $field) {
            if (empty($auth[$field])) {
                outputError("Missing FIEL field: $field");
            }
            if (!file_exists($auth[$field])) {
                outputError("File not found: {$auth[$field]}");
            }
        }

        $certContent = file_get_contents($auth['cert_pem_path']);
        $keyContent  = file_get_contents($auth['key_pem_path']);

        if ($certContent === false || $keyContent === false) {
            outputError('Could not read FIEL certificate or key file');
        }

        // Key was already decrypted by openssl pkcs8 in Rust, so passphrase is empty.
        $credential = Credential::create($certContent, $keyContent, '');
        return makeScraper(FielSessionManager::create($credential));
    })(),

    'ciec' => (static function () use ($auth): SatScraper {
        foreach (['rfc', 'password'] as $field) {
            if (empty($auth[$field])) {
                outputError("Missing CIEC field: $field");
            }
        }
        $resolver = createCaptchaResolver();
        return makeScraper(CiecSessionManager::create($auth['rfc'], $auth['password'], $resolver));
    })(),

    default => outputError("Unknown auth type: '$authType'. Use 'fiel' or 'ciec'"),
};

// --------------------------------------------------------------------------
// Helper: build DownloadType from string
// --------------------------------------------------------------------------
function resolveDownloadType(string $type): DownloadType
{
    return match(strtolower($type)) {
        'recibidos', 'received' => DownloadType::recibidos(),
        default                 => DownloadType::emitidos(),
    };
}

// --------------------------------------------------------------------------
// Helper: build ResourceType from string
// --------------------------------------------------------------------------
function resolveResourceType(string $type): ResourceType
{
    return match(strtolower($type)) {
        'pdf'   => ResourceType::pdf(),
        default => ResourceType::xml(),
    };
}

// --------------------------------------------------------------------------
// Execute command
// --------------------------------------------------------------------------
switch ($command) {

    // ----------------------------------------------------------------------
    // list: query invoices by period or by UUID list
    // ----------------------------------------------------------------------
    case 'list':
        $downloadType = resolveDownloadType($params['download_type'] ?? 'emitidos');

        if (!empty($params['uuids'])) {
            // List by specific UUIDs
            $list = $scraper->listByUuids((array) $params['uuids'], $downloadType);
        } else {
            // List by date period
            if (empty($params['period_from']) || empty($params['period_to'])) {
                outputError("'list' command requires 'period_from' and 'period_to' in params");
            }

            try {
                $from = new DateTimeImmutable($params['period_from']);
                $to   = new DateTimeImmutable($params['period_to']);
            } catch (Throwable $e) {
                outputError('Invalid date format: ' . $e->getMessage());
            }

            $query = new QueryByFilters($from, $to);
            $query->setDownloadType($downloadType);

            if (!empty($params['state'])) {
                $query->setStateVoucher(match(strtolower($params['state'])) {
                    'vigentes', 'active'    => StatesVoucherOption::vigentes(),
                    'cancelados', 'canceled' => StatesVoucherOption::cancelados(),
                    default                 => StatesVoucherOption::todos(),
                });
            }

            $list = $scraper->listByPeriod($query);
        }

        $invoices    = [];
        $typeCounts  = [];
        foreach ($list as $metadata) {
            $data = $metadata->getData();
            $tipo = $data['efectoComprobante'] ?? 'Desconocido';
            $typeCounts[$tipo] = ($typeCounts[$tipo] ?? 0) + 1;
            $invoices[] = $data;
        }

        outputJson([
            'command'      => 'list',
            'total'        => count($invoices),
            'type_counts'  => $typeCounts,
            'invoices'     => $invoices,
        ]);

    // ----------------------------------------------------------------------
    // list-stream: emit one JSON line per invoice as it is found, day by day.
    // Last line: {"__done__":true,"total":N}
    // Rust reads this as SSE and forwards to the browser in real time.
    // ----------------------------------------------------------------------
    case 'list-stream':
        if (empty($params['period_from']) || empty($params['period_to'])) {
            outputError("'list-stream' requires 'period_from' and 'period_to' in params");
        }

        try {
            $streamFrom = new DateTimeImmutable($params['period_from']);
            $streamTo   = new DateTimeImmutable($params['period_to']);
        } catch (Throwable $e) {
            outputError('Invalid date format: ' . $e->getMessage());
        }

        // "ambas" runs both emitidos + recibidos in the same PHP process so that
        // CIEC only authenticates once — two rapid logins for the same RFC cause
        // the SAT to reset the second connection.
        $rawDlType = strtolower($params['download_type'] ?? 'emitidos');
        $streamDownloadTypes = ($rawDlType === 'ambas' || $rawDlType === 'ambos')
            ? [DownloadType::emitidos(), DownloadType::recibidos()]
            : [resolveDownloadType($rawDlType)];

        // When true, each found invoice is immediately downloaded and its XML
        // content sent back as a __xml_ready__ event so Rust can save it to storage.
        $streamAutoXml       = !empty($params['auto_download_xml']);
        // Temp dir for per-invoice XML files (cleaned up as we go).
        $streamXmlTmpDir     = sys_get_temp_dir() . '/pulso_xml_' . getmypid();
        if ($streamAutoXml) {
            @mkdir($streamXmlTmpDir, 0700, true);
        }

        // Disable output buffering so each echo reaches the pipe immediately.
        while (ob_get_level()) { ob_end_clean(); }
        ini_set('output_buffering', 'Off');
        ini_set('implicit_flush', '1');

        $streamTotal      = 0;
        $streamTypeCounts = [];

        foreach ($streamDownloadTypes as $streamDownloadType) {
        // Emit a separator so the browser knows which direction we are querying.
        $dlTypeLabel = ($streamDownloadType === DownloadType::recibidos()) ? 'recibidos' : 'emitidos';
        echo json_encode(['__dl_type__' => $dlTypeLabel], JSON_UNESCAPED_UNICODE) . "\n";
        flush();

        $streamCurrent = $streamFrom;

        while ($streamCurrent->format('Y-m-d') <= $streamTo->format('Y-m-d')) {
            // Keepalive: emit a heartbeat so nginx/proxy doesn't close the SSE
            // connection while we wait for the SAT to respond on this day.
            echo json_encode(['__keepalive__' => true], JSON_UNESCAPED_UNICODE) . "\n";
            flush();

            $dayStart = $streamCurrent->setTime(0, 0, 0);
            $dayEnd   = $streamCurrent->setTime(23, 59, 59);

            $dayQuery = new QueryByFilters($dayStart, $dayEnd);
            $dayQuery->setDownloadType($streamDownloadType);

            try {
                $dayList = $scraper->listByDateTime($dayQuery);
                foreach ($dayList as $metadata) {
                    $data = $metadata->getData();
                    $uuid = strtolower($data['uuid'] ?? '');
                    $tipo = $data['efectoComprobante'] ?? 'Desconocido';
                    $streamTypeCounts[$tipo] = ($streamTypeCounts[$tipo] ?? 0) + 1;
                    $data['_dl_type'] = $dlTypeLabel; // emitidos | recibidos
                    echo json_encode($data, JSON_UNESCAPED_UNICODE) . "\n";
                    flush();
                    $streamTotal++;

                    // Auto-download XML immediately after finding the invoice.
                    // Errors are non-fatal — listing continues regardless.
                    if ($streamAutoXml && $uuid !== '') {
                        try {
                            $singleList = new \PhpCfdi\CfdiSatScraper\MetadataList(
                                [$metadata->uuid() => $metadata]
                            );
                            $scraper->resourceDownloader(ResourceType::xml(), $singleList)
                                ->saveTo($streamXmlTmpDir);
                            $xmlPath = $streamXmlTmpDir . '/' . $uuid . '.xml';
                            if (file_exists($xmlPath)) {
                                $xmlBytes = file_get_contents($xmlPath);
                                echo json_encode([
                                    '__xml_ready__' => true,
                                    'uuid'          => $uuid,
                                    'xml_b64'       => base64_encode($xmlBytes),
                                ], JSON_UNESCAPED_UNICODE) . "\n";
                                flush();
                                unlink($xmlPath); // free disk space immediately
                            }
                        } catch (Throwable $xmlErr) {
                            fwrite(STDERR, 'XML auto-download error ' . $uuid . ': ' . $xmlErr->getMessage() . "\n");
                        }
                    }
                }
            } catch (Throwable $dayError) {
                $errMsg = $dayError->getMessage();
                // Build full cause chain for logging
                $causeChain = $errMsg;
                $cause = $dayError->getPrevious();
                while ($cause !== null) {
                    $causeChain .= ' | caused by: ' . $cause->getMessage();
                    $cause = $cause->getPrevious();
                }
                // Detect SAT session / download limit errors and stop gracefully.
                // The Rust layer saves the job and resumes after 24.5 h.
                if (
                    str_contains($errMsg, '429') ||
                    str_contains($errMsg, 'Too Many') ||
                    str_contains($errMsg, 'bloqueado') ||
                    str_contains($errMsg, 'demasiadas') ||
                    str_contains($errMsg, 'limite') ||
                    str_contains($errMsg, 'limit') ||
                    str_contains($errMsg, 'No tiene acceso') ||
                    str_contains($errMsg, 'SatAuthenticationException') ||
                    ($dayError instanceof \PhpCfdi\CfdiSatScraper\Exceptions\SatException)
                ) {
                    fwrite(STDERR, 'SAT limit/auth error: ' . $causeChain . "\n");
                    echo json_encode([
                        '__limit_reached__' => true,
                        'date'   => $streamCurrent->format('Y-m-d'),
                        'reason' => $causeChain,
                    ], JSON_UNESCAPED_UNICODE) . "\n";
                    flush();
                    exit(0);
                }
                // Non-limit day error — log and continue.
                fwrite(STDERR, 'Day error ' . $streamCurrent->format('Y-m-d') . ': ' . $causeChain . "\n");
            }

            $streamCurrent = $streamCurrent->modify('+1 day');
        }
        } // end foreach $streamDownloadTypes

        // Cleanup temp dir (should already be empty, but just in case)
        if ($streamAutoXml && is_dir($streamXmlTmpDir)) {
            @array_map('unlink', glob($streamXmlTmpDir . '/*'));
            @rmdir($streamXmlTmpDir);
        }

        echo json_encode(['__done__' => true, 'total' => $streamTotal, 'type_counts' => $streamTypeCounts]) . "\n";
        flush();
        exit(0);

    // ----------------------------------------------------------------------
    // download: fetch XML or PDF files for given UUIDs
    // ----------------------------------------------------------------------
    case 'download':
        if (empty($params['uuids'])) {
            outputError("'download' command requires 'uuids' in params");
        }
        if (empty($params['output_dir'])) {
            outputError("'download' command requires 'output_dir' in params");
        }

        $uuids        = (array) $params['uuids'];
        $outputDir    = rtrim($params['output_dir'], '/');
        $downloadType = resolveDownloadType($params['download_type'] ?? 'emitidos');
        $resourceType = resolveResourceType($params['resource_type'] ?? 'xml');

        if (!is_dir($outputDir) && !mkdir($outputDir, 0755, true)) {
            outputError("Could not create output directory: $outputDir");
        }

        // Retrieve metadata for the requested UUIDs
        $list = $scraper->listByUuids($uuids, $downloadType);

        if (count($list) === 0) {
            outputError('No invoices found for the given UUIDs');
        }

        // Count by CFDI type using portal metadata
        $typeCounts = [];
        foreach ($list as $metadata) {
            $data = $metadata->getData();
            $tipo = $data['efectoComprobante'] ?? 'Desconocido';
            $typeCounts[$tipo] = ($typeCounts[$tipo] ?? 0) + 1;
        }

        // Download files to the output directory
        try {
            $scraper->resourceDownloader($resourceType, $list)
                ->saveTo($outputDir);
        } catch (Throwable $dlError) {
            $errMsg = $dlError->getMessage();
            if (
                str_contains($errMsg, '429') ||
                str_contains($errMsg, 'Too Many') ||
                str_contains($errMsg, 'bloqueado') ||
                str_contains($errMsg, 'demasiadas') ||
                str_contains($errMsg, 'limite') ||
                str_contains($errMsg, 'limit') ||
                str_contains($errMsg, 'No tiene acceso') ||
                ($dlError instanceof \PhpCfdi\CfdiSatScraper\Exceptions\SatException)
            ) {
                outputJson([
                    '__limit_reached__' => true,
                    'reason' => $errMsg,
                    'files'  => [], // partial — whatever was saved before the error
                ]);
            }
            outputError('Download failed: ' . $errMsg);
        }

        // Collect info about downloaded files
        $files = [];
        foreach (glob($outputDir . '/*') as $filePath) {
            $files[] = [
                'path'     => $filePath,
                'filename' => basename($filePath),
                'size'     => filesize($filePath),
            ];
        }

        outputJson([
            'command'     => 'download',
            'output_dir'  => $outputDir,
            'type_counts' => $typeCounts,
            'files'       => $files,
        ]);

    // ----------------------------------------------------------------------
    // descarga-masiva: use the SAT bulk download web service (FIEL only).
    //
    // Flow:
    //   1. Build Service with FielRequestBuilder + GuzzleWebClient
    //   2. query()  → get requestId; emit __progress__ queued
    //   3. poll verify() every 5 s until Finished/Failure/Rejected/Expired
    //      emit __progress__ on each poll
    //   4. For each packageId → download() → CfdiPackageReader → save XMLs
    //      emit __progress__ on each downloaded package
    //   5. Final outputJson with summary
    //
    // Params:
    //   period_from, period_to  (ISO-8601 date strings)
    //   download_type           (emitidos|recibidos)
    //   output_dir              (directory where XMLs are written)
    // ----------------------------------------------------------------------
    case 'descarga-masiva':
        if ($authType !== 'fiel') {
            outputError("'descarga-masiva' only supports FIEL authentication");
        }
        if (empty($params['period_from']) || empty($params['period_to'])) {
            outputError("'descarga-masiva' requires 'period_from' and 'period_to' in params");
        }
        if (empty($params['output_dir'])) {
            outputError("'descarga-masiva' requires 'output_dir' in params");
        }

        $dmOutputDir = rtrim($params['output_dir'], '/');
        if (!is_dir($dmOutputDir) && !mkdir($dmOutputDir, 0755, true)) {
            outputError("Could not create output directory: $dmOutputDir");
        }

        // Read FIEL credentials (already validated above when building $scraper)
        $dmCertContent = file_get_contents($auth['cert_pem_path']);
        $dmKeyContent  = file_get_contents($auth['key_pem_path']);
        if ($dmCertContent === false || $dmKeyContent === false) {
            outputError('Could not read FIEL certificate or key file');
        }

        // Build the sat-ws-descarga-masiva Service
        $dmFiel    = Fiel::create($dmCertContent, $dmKeyContent, '');
        if (!$dmFiel->isValid()) {
            outputError('FIEL credential is not valid or not a FIEL certificate');
        }
        $dmBuilder = new FielRequestBuilder($dmFiel);
        $dmGuzzle  = new GuzzleClient([
            'verify' => resolveGuzzleVerify(),
            'curl'   => [CURLOPT_SSL_CIPHER_LIST => 'DEFAULT@SECLEVEL=1'],
        ]);
        $dmWebClient = new GuzzleWebClient($dmGuzzle);
        $dmService   = new Service($dmBuilder, $dmWebClient);

        // Build monthly chunks from period_from → period_to
        // The SAT bulk download API works best with ≤1 month per request.
        $dmDownloadTypeWs = strtolower($params['download_type'] ?? 'emitidos') === 'recibidos'
            ? WsDownloadType::received()
            : WsDownloadType::issued();

        try {
            $dmRangeStart = new DateTimeImmutable($params['period_from']);
            $dmRangeEnd   = new DateTimeImmutable($params['period_to']);
        } catch (Throwable $e) {
            outputError('Invalid date format: ' . $e->getMessage());
        }

        // Build list of (start, end) pairs, one per calendar month in the range
        $dmChunks = [];
        $dmCursor = $dmRangeStart->setTime(0, 0, 0);
        while ($dmCursor <= $dmRangeEnd) {
            $dmMonthEnd = new DateTimeImmutable(
                $dmCursor->format('Y-m-') . $dmCursor->format('t') . ' 23:59:59'
            );
            $dmChunkEnd = $dmMonthEnd < $dmRangeEnd ? $dmMonthEnd : $dmRangeEnd->setTime(23, 59, 59);
            $dmChunks[] = [$dmCursor, $dmChunkEnd];
            // Advance to the first day of the next month
            $dmCursor = (new DateTimeImmutable($dmCursor->format('Y-m-01')))->modify('+1 month');
        }

        $dmTotalFiles    = 0;
        $dmFiles         = [];
        $dmTotalChunks   = count($dmChunks);

        foreach ($dmChunks as $dmChunkIdx => [$dmChunkStart, $dmChunkEnd]) {
            $dmMonthLabel = $dmChunkStart->format('Y-m');

            echo json_encode([
                '__progress__' => true,
                'stage'        => 'month_start',
                'month'        => $dmMonthLabel,
                'chunk'        => $dmChunkIdx + 1,
                'total_chunks' => $dmTotalChunks,
            ], JSON_UNESCAPED_UNICODE) . "\n";
            flush();

            // ── Step 1: Query ──────────────────────────────────────────────
            try {
                $dmPeriod = DateTimePeriod::createFromValues($dmChunkStart, $dmChunkEnd);
            } catch (Throwable $e) {
                fwrite(STDERR, 'Invalid period for ' . $dmMonthLabel . ': ' . $e->getMessage() . "\n");
                continue;
            }

            $dmQueryParams = QueryParameters::create(
                period: $dmPeriod,
                downloadType: $dmDownloadTypeWs,
                requestType: RequestType::cfdi(),
            );

            $dmQueryResult = $dmService->query($dmQueryParams);
            if (!$dmQueryResult->getStatus()->isAccepted()) {
                fwrite(STDERR, 'SAT rejected query for ' . $dmMonthLabel . ': ' . $dmQueryResult->getStatus()->getMessage() . "\n");
                continue;
            }
            $dmRequestId = $dmQueryResult->getRequestId();

            echo json_encode([
                '__progress__' => true,
                'stage'        => 'queued',
                'month'        => $dmMonthLabel,
                'request_id'   => $dmRequestId,
            ], JSON_UNESCAPED_UNICODE) . "\n";
            flush();

            // ── Step 2: Poll verify ────────────────────────────────────────
            $dmPackageIds = [];
            $dmMaxPolls   = 120; // up to 10 min per month (5 s × 120)
            $dmSuccess    = false;
            for ($dmPoll = 0; $dmPoll < $dmMaxPolls; $dmPoll++) {
                sleep(5);

                $dmVerifyResult = $dmService->verify($dmRequestId);
                $dmStatusReq    = $dmVerifyResult->getStatusRequest();

                echo json_encode([
                    '__progress__' => true,
                    'stage'        => 'verifying',
                    'month'        => $dmMonthLabel,
                    'request_id'   => $dmRequestId,
                    'status'       => $dmStatusReq->getMessage(),
                    'cfdis'        => $dmVerifyResult->getNumberCfdis(),
                    'packages'     => $dmVerifyResult->countPackages(),
                ], JSON_UNESCAPED_UNICODE) . "\n";
                flush();

                if ($dmStatusReq->isFinished()) {
                    $dmPackageIds = $dmVerifyResult->getPackagesIds();
                    $dmSuccess    = true;
                    break;
                }
                if ($dmStatusReq->isFailure() || $dmStatusReq->isRejected() || $dmStatusReq->isExpired()) {
                    fwrite(STDERR, 'Bulk request failed for ' . $dmMonthLabel . ': ' . $dmStatusReq->getMessage() . "\n");
                    break;
                }
            }

            if (!$dmSuccess) {
                fwrite(STDERR, 'Timed out or failed for ' . $dmMonthLabel . " (request_id: $dmRequestId)\n");
                continue;
            }

            // ── Step 3: Download packages ──────────────────────────────────
            foreach ($dmPackageIds as $dmPkgIdx => $dmPkgId) {
                echo json_encode([
                    '__progress__' => true,
                    'stage'        => 'downloading',
                    'month'        => $dmMonthLabel,
                    'request_id'   => $dmRequestId,
                    'package'      => $dmPkgIdx + 1,
                    'total_pkgs'   => count($dmPackageIds),
                ], JSON_UNESCAPED_UNICODE) . "\n";
                flush();

                $dmDownloadResult = $dmService->download($dmPkgId);
                if (!$dmDownloadResult->getStatus()->isAccepted()) {
                    fwrite(STDERR, 'Package download failed (' . $dmPkgId . '): ' . $dmDownloadResult->getStatus()->getMessage() . "\n");
                    continue;
                }

                $dmTmpZip = tempnam(sys_get_temp_dir(), 'sat_pkg_') . '.zip';
                file_put_contents($dmTmpZip, $dmDownloadResult->getPackageContent());

                try {
                    $dmReader = CfdiPackageReader::createFromFile($dmTmpZip);
                    foreach ($dmReader as $dmUuid => $dmXmlContent) {
                        $dmFilePath = $dmOutputDir . '/' . strtolower($dmUuid) . '.xml';
                        file_put_contents($dmFilePath, $dmXmlContent);
                        $dmFiles[] = [
                            'uuid'     => strtolower($dmUuid),
                            'path'     => $dmFilePath,
                            'filename' => basename($dmFilePath),
                            'size'     => strlen($dmXmlContent),
                        ];
                        $dmTotalFiles++;
                    }
                } finally {
                    @unlink($dmTmpZip);
                }
            }

            echo json_encode([
                '__progress__' => true,
                'stage'        => 'month_done',
                'month'        => $dmMonthLabel,
                'month_total'  => $dmTotalFiles,
            ], JSON_UNESCAPED_UNICODE) . "\n";
            flush();
        }

        outputJson([
            'command'     => 'descarga-masiva',
            'request_id'  => $dmRequestId ?? null,
            'total'       => $dmTotalFiles,
            'files'       => $dmFiles,
        ]);

    default:
        outputError("Unknown command: '$command'. Use 'list', 'list-stream', 'download', or 'descarga-masiva'");
}
